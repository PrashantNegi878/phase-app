rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // USER DOCUMENTS
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // PARTNER CODES LOOKUP TABLE
    match /partnerCodes/{code} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.resource.data.trackerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.trackerId == request.auth.uid;
    }

    // TRACKER PROFILES
    match /trackerProfiles/{trackerId} {
      allow read: if isOwner(trackerId) || (
        isAuthenticated() &&
        exists(/databases/$(database)/documents/partnerProfiles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/partnerProfiles/$(request.auth.uid)).data.linkedTrackerId == trackerId
      );
      allow create, update, delete: if isOwner(trackerId);
    }

    // PARTNER PROFILES
    match /partnerProfiles/{partnerId} {
      allow read: if isOwner(partnerId) || (
        isAuthenticated() && resource.data.linkedTrackerId == request.auth.uid
      );
      allow create, update, delete: if isOwner(partnerId);
    }

    // CYCLE DATA
    match /cycleData/{userId} {
      allow read: if isOwner(userId) || (
        isAuthenticated() &&
        exists(/databases/$(database)/documents/partnerProfiles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/partnerProfiles/$(request.auth.uid)).data.linkedTrackerId == userId
      );
      allow create, update, delete: if isOwner(userId);
    }

    // DAILY LOGS
    match /dailyLogs/{docId} {
      allow read: if isOwner(resource.data.userId) || (
        isAuthenticated() &&
        exists(/databases/$(database)/documents/partnerProfiles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/partnerProfiles/$(request.auth.uid)).data.linkedTrackerId == resource.data.userId
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }

    // CYCLE HISTORY
    match /cycleHistory/{docId} {
      allow read: if isOwner(resource.data.userId) || (
        isAuthenticated() &&
        exists(/databases/$(database)/documents/partnerProfiles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/partnerProfiles/$(request.auth.uid)).data.linkedTrackerId == resource.data.userId
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

